# ============================================================
# .env.example — copy to .env.local and fill in real values
# ============================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=invoicing

# AWS S3 / Rustfs (S3-compatible object storage)
AWS_USERNAME=your-rustfs-access-key
AWS_PASSWORD=your-rustfs-secret-key
AWS_REGION=us-east-1
AWS_URL=http://localhost:10000
AWS_BUCKET=invoicing

# Email (Mailhog for local dev)
MAILHOG_HOST=localhost
MAIL_PORT=1025

# Next.js
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
